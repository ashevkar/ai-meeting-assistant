# Copy this file to .env and fill in your values
# Generate a secret: openssl rand -hex 32

# --- Option A: OpenAI (paid, ~$0.01-0.05/meeting) ---
# OPENAI_API_KEY=sk-...your key from platform.openai.com...

# --- Option B: Groq (free tier, sign up at console.groq.com) ---
# OPENAI_API_KEY=gsk_...your key from console.groq.com...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=your_key_here
SECRET_KEY=your_random_secret_here_minimum_32_chars
